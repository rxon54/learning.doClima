		<style type="text/css" id="wp-custom-css">
			/*navigation head  */ 
#g-navigation {
    border-top: 0;
    border-bottom: 0;
    padding-bottom: 20px;
    background-image: url('/wp-content/uploads/2017/06/yellowborder.jpg');
    background-position: bottom left;
    background-repeat: repeat-x
}

#g-navigation .fa {
    font-size: 1.5rem
}

.g-main-nav .g-toplevel i.fa-home {
    opacity: 1
}

.g-main-nav .g-toplevel > li > .g-menu-item-container > .g-menu-item-content {
    font-size: 0.95rem
}



/*   Dropdown background  */
#g-navigation .g-main-nav .g-dropdown {
    background: #009b90
}     

 /*  Homebutton background  */
#g-navigation .g-main-nav .g-toplevel > li.active > .g-menu-item-container {
    color: #fff;
    background: #009b90 
}  

/* Hover on Social Icons*/ 
.g-social a:hover {
    color: #fff;
    background: #00887c
} 

/* hover Dropdown */
#g-navigation .g-main-nav .g-toplevel > li:hover > .g-menu-item-container {
    color: #fff;
    background: #00887c
}  



/* Change text color on articles */
.box2.moduletable,.box2.widget,.box2 > .g-content {
    background: #fff;
    color: #000;
}  


/* Copyright list Contact sitemap  */
ul.list-inline {  
    margin: 0 auto;
    padding: 0;
    list-style-type: none;
    text-align: center;
}

ul.list-inline li {
    display: inline;
    margin-right: 10px
}


#g-copyright a {
    color: #ffffff;
}

#g-copyright a:hover {
    text-decoration: underline
}
.g-main-nav .g-standard .g-dropdown {
    width: 350px;
    float: left;
}
/* NEWS content   */ 

.news-main,.news-next {
    color: #000; 
}

/* Button color and Hover */ 
.button {
border-radius: 20px;
    background: #009b90;
}

.button:hover,.button:active,.button:focus {
    background: #00877c; 
}

  

/* test artiklar */ 
.articlesHome,.news-next {
    margin-bottom: 30px
}

.news-main,.news-next {
    color: black;
}

.news-main-item {
    display: table;
    width: 100%
}

.news-main-item .news-main-item-title {
    font-size: 1.6rem;
    padding: 0;
    display: table-cell !important;
    vertical-align: bottom
}

.news-main-item .news-main-item-date {
    font-size: 1.2rem;
    padding: 0;
    display: table-cell !important;
    vertical-align: bottom;
    text-align: right
}

.news-next {
    font-size: 1.125rem
}

.news-next h3 {
    font-size: 1.4rem
}

.news-next .news-date {
    font-size: 1rem;
    text-align: right
}

.news-next .news-category {
    font-size: 1.2rem
}

/* RokSprocket Color button */ 
.layout-showcase .sprocket-features-pagination li, .layout-showcase .sprocket-features-arrows .arrow {
    background: #009b90;
  }


/* Cordex sidebar Highlight */ 
.cordex-highlight {
    -moz-box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);
    -webkit-box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);
    margin: 15px 0 0
}

.cordex-highlight h2 {
    background-color: #d3eeed;
    color: #009e90;
    margin: 0;
    padding: 10px 10px;
    text-transform: uppercase;
    text-align: center
}

.cordex-highlight li {
    list-style-type: none
}

.cordex-highlight .g-promoimage .g-promoimage-effect {
    -webkit-border-radius: 0;
    -moz-border-radius: 0;
    border-radius: 0
}

.cordex-highlight .g-promoimage .g-promoimage-effect img {
    opacity: 1
}

.cordex-highlight .g-promoimage .g-promoimage-effect:hover {
    background-color: #1881ab
}

.cordex-highlight .g-promoimage .g-promoimage-desc a,.cordex-highlight .g-promoimage .g-promoimage-desc a:hover,.g-promoimage .g-promoimage-desc a:focus {
    text-decoration: none;
    color: #fff
}

.cordex-highlight .g-promoimage .g-promoimage-iconbutton {
    color: #009e90;
    background-color: #d3eeed;
    border-color: #00887c
}

.cordex-highlight .g-promoimage .fa-fw {
    font-size: 1.2em
}

.articlesHome,.news-next {
    margin-bottom: 30px
}
.emailtext, .email {
	font-weight:bold;
}

.emailtext::before, .email:before {
	content:' ';
	float:left;
	background:#ffcc05;
	height:20px;
	width:10px;
	margin-right:5px;
}
/**News list*/
.newslist .g-item-title {
	border-top:4px solid #79ccc8;
	padding-top:10px;
}
/*Sciencelist*/
.sciencehighlight .g-item-title {
	border-top:4px solid #ffca00;
	padding-top:10px;
}
/*Related event */
.relatedevent h2{
	margin:0;
	margin-bottom:-2em;
}
.relatedeventblock .g-array-item {
	margin-bottom:0;
}
.relatedeventblock .g-item-title {
	font-size:1.0em;
}
.relatedeventblock .g-array-item-text {
	margin:0;
}
.relatedeventblock .g-array-item-text p {
	margin:0.2em;
}
h6 {
	    font-size: 1em;
    color: #009b90;
    font-weight: bold;
}		</style>
		
                
</head>

    
