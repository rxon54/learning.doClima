<script src="https://seeg.eco.br/wp-content/plugins/elementor-pro/assets/js/elements-handlers.min.js?ver=3.34.3" id="pro-elements-handlers-js"></script>
<script>
(function () {
  var HEADER_OFFSET = 80;



  /* SMOOTH SCROLL: OFFSET ANCHORS UNDER STICKY HEADER */
  function smoothTo(el) {
    var top = el.getBoundingClientRect().top + window.pageYOffset - HEADER_OFFSET;
    window.scrollTo({ top: top, behavior: 'smooth' });
  }

  function isSamePageAnchor(a) {
    try {
      var url = new URL(a.href, location.href);
      return url.pathname === location.pathname && url.hash && url.hash !== '#';
    } catch (e) {
      return false;
    }
  }



  /* CLICK HANDLER: SMOOTH ANCHORS + CLOSE ON OUTSIDE CLICK */
  function onClick(e) {
    var a = e.target.closest('a[href]');
    if (a && isSamePageAnchor(a)) {
      var id = decodeURIComponent(a.hash.slice(1));
      var target = document.getElementById(id);
      if (target) {
        e.preventDefault();
        smoothTo(target);
        return;
      }
    }

    document.querySelectorAll('.elementor-widget-nav-menu').forEach(function (widget) {
      var toggle = widget.querySelector('.elementor-menu-toggle');
      var dropdown = widget.querySelector('.elementor-nav-menu--dropdown');
      if (!toggle || !dropdown) return;

      var isOpen = toggle.getAttribute('aria-expanded') === 'true';

      /* CLOSE IF CLICKED OUTSIDE */
      if (isOpen && !dropdown.contains(e.target) && !toggle.contains(e.target)) {
        toggle.click();
        return;
      }

      /* IF STILL OPEN, KEEP IT ALIGNED UNDER THE TOGGLE */
      if (isOpen) positionDropdown(widget);
    });
  }



  /* KEYBOARD UX: ESC CLOSES ANY OPEN NAV DROPDOWNS */
  function onKeydown(e) {
    if (e.key === 'Escape') {
      document
        .querySelectorAll('.elementor-widget-nav-menu .elementor-menu-toggle[aria-expanded="true"]')
        .forEach(function (btn) { btn.click(); });
    }
  }



  /* SAFETY NET: RESET CLOSED MENUS' INLINE STYLES */
  function hideClosedDropdowns() {
    document.querySelectorAll('.elementor-widget-nav-menu').forEach(function (widget) {
      var toggle = widget.querySelector('.elementor-menu-toggle');
      var dropdown = widget.querySelector('.elementor-nav-menu--dropdown');
      if (!toggle || !dropdown) return;

      var isOpen = toggle.getAttribute('aria-expanded') === 'true';
      if (!isOpen) {
        dropdown.style.display = '';
        dropdown.style.maxHeight = '';
        dropdown.style.visibility = '';
        dropdown.style.pointerEvents = '';
        dropdown.style.opacity = '';
        resetDropdownPosition(dropdown); /* NEW: clear pinning when closed */
      }
    });
  }



  /* KILL OPTIONAL LOADER ELEMENT (#pan-loader) IF PRESENT */
  function killLoader() {
    var l = document.getElementById('pan-loader');
    if (l && l.parentNode) l.parentNode.removeChild(l);
  }



  /* ON LOAD: HONOR URL HASH WITH SMOOTH OFFSET */
  function fixHashOnLoad() {
    if (location.hash.length > 1) {
      var id = decodeURIComponent(location.hash.slice(1));
      var t = document.getElementById(id);
      if (t) setTimeout(function () { smoothTo(t); }, 0);
    }
  }



  /* ANTI-STUCK SCROLL: FALLBACK FOR WHEEL/TOUCH SCENARIOS */
  function installAntiStall() {
    window.addEventListener('wheel', function (e) {
      if (e.defaultPrevented) return;
      var before = window.pageYOffset;
      requestAnimationFrame(function () {
        var after = window.pageYOffset;
        if (after === before && Math.abs(e.deltaY) > 0.5) window.scrollBy(0, e.deltaY);
      });
    }, { passive: true });

    var touchStartY = null;
    window.addEventListener('touchstart', function (e) {
      if (e.touches && e.touches[0]) touchStartY = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchmove', function (e) {
      if (!e.touches || touchStartY == null) return;
      var dy = touchStartY - e.touches[0].clientY;
      var before = window.pageYOffset;
      requestAnimationFrame(function () {
        var after = window.pageYOffset;
        if (after === before && Math.abs(dy) > 2) window.scrollBy(0, dy);
      });
    }, { passive: true });
  }



  /* NEW: PIN DROPDOWN 40PX BELOW THE TOGGLE */
  function positionDropdown(widget) {
    var toggle = widget.querySelector('.elementor-menu-toggle');
    var dropdown = widget.querySelector('.elementor-nav-menu--dropdown');
    if (!toggle || !dropdown) return;

    var isOpen = toggle.getAttribute('aria-expanded') === 'true';
    if (!isOpen) { resetDropdownPosition(dropdown); return; }

    var rect = toggle.getBoundingClientRect();
    dropdown.style.position = 'fixed';
    dropdown.style.top = (rect.bottom + 40) + 'px';
    dropdown.style.left = rect.left + 'px';
    dropdown.style.width = rect.width + 'px';
    dropdown.style.maxWidth = 'calc(100vw - 20px)';
    dropdown.style.margin = '0';
    dropdown.style.transform = 'none';
    dropdown.style.zIndex = '9999';
    dropdown.style.right = '';
  }



  /* NEW: CLEAR PINNING WHEN CLOSED */
  function resetDropdownPosition(dropdown) {
    dropdown.style.position = '';
    dropdown.style.top = '';
    dropdown.style.left = '';
    dropdown.style.width = '';
    dropdown.style.maxWidth = '';
    dropdown.style.margin = '';
    dropdown.style.transform = '';
    dropdown.style.zIndex = '';
    dropdown.style.right = '';
  }



  /* NEW: KEEP OPEN MENUS ALIGNED ON SCROLL/RESIZE */
  function syncOpenMenus() {
    document.querySelectorAll('.elementor-widget-nav-menu .elementor-menu-toggle[aria-expanded="true"]')
      .forEach(function (btn) { positionDropdown(btn.closest('.elementor-widget-nav-menu')); });
  }



  /* INIT */
  document.addEventListener('DOMContentLoaded', function () {
    document.addEventListener('click', onClick, { passive: false });
    document.addEventListener('keydown', onKeydown);

    hideClosedDropdowns();
    killLoader();
    fixHashOnLoad();
    installAntiStall();

    var mo = new MutationObserver(function () {
      hideClosedDropdowns();
      syncOpenMenus(); /* NEW */
    });
    mo.observe(document.documentElement, {
      childList: true,
      subtree: true,
      attributes: true,
      attributeFilter: ['class', 'aria-expanded']
    });

    window.addEventListener('scroll', syncOpenMenus, { passive: true });  /* NEW */
    window.addEventListener('resize', syncOpenMenus);                     /* NEW */

    document.body.style.overflowY = 'auto';
  });
})();
</script>


